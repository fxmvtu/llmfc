<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 模型下载需要网络 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Vulkan / GPU 加速 — llama.cpp 可通过 GGML 使用 Vulkan 通用 GPU 计算 -->
    <uses-feature android:glEsVersion="0x00030000" android:required="false" />

    <!-- IPC permission — required by the app to bind this service -->
    <uses-permission android:name="${mainApplicationId}.permission.IPC" />

    <application
        android:icon="@mipmap/ic_launcher_plugin_generic"
        android:label="@string/app_name">

        <!--
          MainService — FcitxPluginService that registers IInputSuggestions
          with the main app's FcitxRemoteService so LLM candidates can be
          injected into the输入法 candidate view.
        -->
        <service
            android:name=".MainService"
            android:exported="true"
            android:permission="${mainApplicationId}.permission.PLUGIN"
            tools:targetApi="24">
            <intent-filter>
                <action android:name="${mainApplicationId}.plugin.SERVICE" />
            </intent-filter>
        </service>

        <!-- 设置页 Activity -->
        <activity
            android:name=".ui.AIComposeSettingsActivity"
            android:exported="false"
            android:label="@string/settings_title" />
    </application>
</manifest>
